# ---- توكن بوت الديسكورد (من Discord Developer Portal) ----
DISCORD_TOKEN=REPLACE_ME

# ---- جوجل درايف (Service Account) ----
# مسار ملف الـ JSON بتاع الـ Service Account
GOOGLE_SERVICE_ACCOUNT_FILE=REPLACE_ME
# آيدي فولدر على درايف (اختياري) هيتحط جواه كل الفصولات الناتجة
# لو سبته فاضي، الفولدرات هتتعمل في درايف الـ Service Account نفسه
GOOGLE_DRIVE_PARENT_FOLDER_ID=REPLACE_ME

# ---- إعدادات SmartStitch الافتراضية (زي اللي في اللقطة اللي بعتها) ----
DEFAULT_OUTPUT_FORMAT=REPLACE_ME
DEFAULT_LOSSY_QUALITY=REPLACE_ME
DEFAULT_SPLIT_HEIGHT=REPLACE_ME
DEFAULT_CUSTOM_WIDTH=REPLACE_ME
DEFAULT_DETECTION_TYPE=REPLACE_ME
DEFAULT_SENSITIVITY=REPLACE_ME
DEFAULT_IGNORABLE_PIXELS=REPLACE_ME
DEFAULT_SCAN_LINE_STEP=REPLACE_ME

# ---- إعدادات عامة ----
WORK_DIR=REPLACE_ME
MAX_ZIP_SIZE_MB=REPLACE_ME
